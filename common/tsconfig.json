{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./build",
    "module": "node16",
    "target": "ES2019",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",
    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ]
  }
}