{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./build",
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2019",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*"
  ]
}